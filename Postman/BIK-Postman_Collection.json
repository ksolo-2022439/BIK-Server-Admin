								{
									"listen": "test",
									"script": {
										"type": "text/javascript",
										"exec": [
											"pm.test('Estado 200', function () {",
											"  pm.response.to.have.status(200);",
											"});",
											"let jsonData = {};",
											"try { jsonData = pm.response.json(); } catch (e) {}",
											"const token = jsonData?.userDetails?.token;",
											"pm.test('Token guardado', function () {",
											"  pm.expect(token).to.be.a('string').and.not.empty;",
											"});",
											"if (token) pm.collectionVariables.set('token', token);"
										]
									}
								}
							],
