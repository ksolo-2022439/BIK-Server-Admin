# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Configuración de Base de Datos (Preparación para la Fase 2)
MONGODB_URI=mongodb://127.0.0.1:27017/bik_core_db

# URL del servicio de autenticación C# (.NET 8)
AUTH_SERVICE_URL=http://localhost:5213

# URL del cliente frontend (para CORS)
CLIENT_URL=http://localhost:5173

# Clave secreta compartida con BIK-Auth-Service (C#)
JWT_SECRET=TuClaveSecretaSuperSeguraParaValidarTokensDeCSharp